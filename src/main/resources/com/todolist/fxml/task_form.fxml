<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.todolist.controller.TaskFormController"
      stylesheets="@../css/style.css"
      styleClass="dialog-root"
      prefWidth="500">

    <!-- Dialog Header -->
    <HBox styleClass="dialog-header" alignment="CENTER_LEFT">
        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
        <Label fx:id="dialogTitleLabel" text="Tambah Task Baru" styleClass="dialog-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="btn-close" onAction="#onCancel"/>
    </HBox>

    <!-- Form Body -->
    <VBox styleClass="dialog-body" spacing="18">
        <padding><Insets top="24" right="24" bottom="8" left="24"/></padding>

        <!-- Title -->
        <VBox spacing="6">
            <Label text="Judul Task  *" styleClass="form-label"/>
            <TextField fx:id="titleField"
                       promptText="Masukkan judul task..."
                       styleClass="form-input"/>
            <Label fx:id="titleError" text="⚠  Judul tidak boleh kosong"
                   styleClass="error-label" visible="false"/>
        </VBox>

        <!-- Description -->
        <VBox spacing="6">
            <Label text="Deskripsi" styleClass="form-label"/>
            <TextArea fx:id="descField"
                      promptText="Tambahkan deskripsi (opsional)..."
                      styleClass="form-textarea"
                      prefRowCount="3"
                      wrapText="true"/>
        </VBox>

        <!-- Category & Priority (side by side) -->
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Kategori" styleClass="form-label"/>
                <ComboBox fx:id="categoryCombo" maxWidth="Infinity" styleClass="form-combo"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Prioritas" styleClass="form-label"/>
                <ComboBox fx:id="priorityCombo" maxWidth="Infinity" styleClass="form-combo"/>
            </VBox>
        </HBox>

        <!-- Deadline -->
        <VBox spacing="6">
            <Label text="Deadline  (opsional)" styleClass="form-label"/>
            <DatePicker fx:id="deadlinePicker"
                        promptText="Pilih tanggal..."
                        maxWidth="Infinity"
                        styleClass="form-datepicker"/>
        </VBox>
    </VBox>

    <!-- Dialog Footer -->
    <HBox styleClass="dialog-footer" alignment="CENTER_RIGHT" spacing="12">
        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
        <Button text="Batal"       styleClass="btn-secondary" onAction="#onCancel"/>
        <Button text="Simpan Task" styleClass="btn-primary"   onAction="#onSave"/>
    </HBox>

</VBox>
